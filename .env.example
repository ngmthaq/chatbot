# Environment variables for the server application
NEST_APP_PORT=9000
NEST_APP_NAME=Chatbot App
NEST_APP_CLIENT_URL=http://localhost:9007

# Cache settings
NEST_APP_CACHE_TTL=60000
NEST_APP_CACHE_LRU_SIZE=5000

# Security settings
NEST_APP_CRYPTO_ALGORITHM=aes-256-cbc
NEST_APP_CRYPTO_SECRET=your-secret-key
NEST_APP_SALT_ROUNDS=10

# JWT settings
NEST_APP_JWT_SECRET=your-jwt-secret
NEST_APP_JWT_EXPIRATION=1H

# Refresh token settings
NEST_APP_RT_EXPIRATION_NUMBER=30
NEST_APP_RT_EXPIRATION_UNIT=days

# User activation token settings
NEST_APP_AT_EXPIRATION_NUMBER=1
NEST_APP_AT_EXPIRATION_UNIT=days

# User reset password token settings
NEST_APP_RPT_EXPIRATION_NUMBER=1
NEST_APP_RPT_EXPIRATION_UNIT=hours

# Docker services - Database
MYSQL_ROOT_PASSWORD=root
MYSQL_DATABASE=app_db
MYSQL_USER=app_user
MYSQL_PASSWORD=app_password
MYSQL_HOST=localhost
MYSQL_PORT=9001

# Docker services - Message Queue
MESSAGE_QUEUE_REDIS_HOST=localhost
MESSAGE_QUEUE_REDIS_PORT=9002

# Docker services - Cache
CACHE_REDIS_HOST=localhost
CACHE_REDIS_PORT=9003

# Docker services - Adminer
ADMINER_PORT=9004

# Docker services - Ollama
OLLAMA_HOST=localhost
OLLAMA_PORT=9005
OLLAMA_CHAT_MODEL=gemma3
OLLAMA_EMBED_MODEL=embeddinggemma
OLLAMA_VISION_MODEL=gemma3

# Docker services - Qdrant
QDRANT_HOST=localhost
QDRANT_PORT=9006
QDRANT_API_KEY=

# RAG & Chat Configuration
DEFAULT_CONTEXT_WINDOW=20
DEFAULT_TEMPERATURE=0.7
DEFAULT_MAX_TOKENS=2048
DEFAULT_PAGE_SIZE=20
MAX_PAGE_SIZE=100

# File Upload
UPLOAD_DIR=/uploads
MAX_FILE_SIZE=52428800

# Mail Configuration
MAIL_MAILER=smtp
MAIL_HOST=sandbox.smtp.mailtrap.io
MAIL_PORT=2525
MAIL_USERNAME=your-mailtrap-username
MAIL_PASSWORD=your-mailtrap-password
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=noreply@example.com
MAIL_FROM_NAME=Chatbot App

# Client Configuration
VITE_APP_PORT=9007
VITE_API_BASE_URL=http://localhost:9000

# SSL / Corporate Proxy Certificate
# Set the absolute path to your CA certificate (.pem) if you're behind a corporate proxy.
# Leave empty on machines that don't require a custom CA certificate.
# Example: CA_CERT_PATH=/Users/your-name/Cert/MWG.pem
CA_CERT_PATH=
