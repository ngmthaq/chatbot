{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "sourceRoot": "src",
  "generateOptions": {
    "spec": false
  },
  "compilerOptions": {
    "deleteOutDir": true,
    "assets": [
      {
        "watchAssets": true,
        "include": "core/email/templates/**/*",
        "outDir": "dist/src"
      }
    ]
  }
}