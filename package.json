{
  "name": "chatbot",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "check-types": "turbo run check-types",
    "db:generate": "node ./scripts/generate-prisma.cjs",
    "db:migrate-dev": "turbo run db:migrate-dev",
    "db:migrate-prod": "turbo run db:migrate-prod",
    "db:seed": "turbo run db:seed",
    "debug": "turbo run debug",
    "dev": "turbo run dev",
    "docker:base-up": "docker compose -f docker-compose-base.yml up -d --build",
    "docker:base-down": "docker compose -f docker-compose-base.yml down",
    "docker:prod-up": "docker compose -f docker-compose-prod.yml up -d --build",
    "docker:prod-down": "docker compose -f docker-compose-prod.yml down",
    "onboarding": "node ./scripts/onboarding.cjs",
    "ollama:install": "node ./scripts/install-ollama-models.cjs",
    "format": "prettier --write .",
    "lint": "turbo run lint",
    "prod": "turbo run prod"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@types/node": "^24.10.1",
    "@vitejs/plugin-react": "^5.1.1",
    "dotenv": "^17.3.1",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.1",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-prettier": "^5.5.4",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "eslint-plugin-turbo": "^2.6.0",
    "globals": "^16.5.0",
    "prettier": "^3.7.4",
    "turbo": "^2.6.3",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.49.0",
    "vite": "^7.2.4"
  },
  "packageManager": "yarn@1.22.22",
  "engines": {
    "node": ">=18"
  }
}
